# ============================================
# EDUSYNC BACKEND CONFIGURATION
# ============================================

# Application Settings
APP_NAME=EduSync - College ERP
APP_VERSION=1.0.0
DEBUG=True

# API Configuration
API_V1_STR=/api/v1

# ============================================
# DATABASE CONFIGURATION
# ============================================

# Supabase Configuration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# PostgreSQL Connection String (if not using Supabase)
DATABASE_URL=postgresql://user:password@localhost:5432/edusync

# ============================================
# JWT CONFIGURATION
# ============================================

JWT_SECRET=your-super-secret-jwt-key-min-32-characters-long
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24
REFRESH_TOKEN_EXPIRATION_DAYS=7

# ============================================
# CORS CONFIGURATION
# ============================================

CORS_ORIGINS=["http://localhost:3000", "http://localhost:8000", "http://127.0.0.1:3000", "http://127.0.0.1:8000"]

# ============================================
# EMAIL CONFIGURATION (Optional)
# ============================================

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
EMAILS_FROM_EMAIL=noreply@edusync.com

# ============================================
# SECURITY SETTINGS
# ============================================

SECURE_COOKIES=False
SAME_SITE=lax
